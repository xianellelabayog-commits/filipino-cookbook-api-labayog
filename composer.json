{
  "name": "filipino-cookbook-api/filipino-cookbook-api",
  "description": "Filipino cookbook API project",
  "type": "project",
  "require": {
    "php": "^8.0",
    "slim/slim": "^4.10",
    "slim/psr7": "^1.8"
  },
  "autoload": {
    "psr-4": {
      "App\\": "public/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "secure-http": false,
    "disable-tls": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [{
    "name": "packagist",
    "type": "composer",
    "url": "http://repo.packagist.org"
  }]
}
